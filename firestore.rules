rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USER PROFILE VALIDATION ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'lastActive', 'balance']) &&
             data.keys().size() <= 10 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.balance is number &&
             data.lastActive is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      // --- CATEGORIES SUB-COLLECTION ---
      match /categories/{categoryId} {
        function isValidCategory(data) {
          return data.keys().hasAll(['name', 'emoji', 'type', 'createdAt']) &&
                 data.keys().size() == 4 &&
                 data.name is string && data.name.size() <= 50 &&
                 data.emoji is string && data.emoji.size() <= 10 &&
                 data.type in ['expense', 'income'] &&
                 data.createdAt is timestamp;
        }
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming());
        allow delete: if isOwner(userId);
      }

      // --- TRANSACTIONS SUB-COLLECTION ---
      match /transactions/{transactionId} {
        function isValidTransaction(data) {
          return data.keys().hasAll(['amount', 'type', 'category', 'timestamp']) &&
                 data.keys().size() <= 6 &&
                 data.amount is number &&
                 data.type in ['expense', 'income'] &&
                 data.category is string && data.category.size() <= 50 &&
                 (data.keys().hasAny(['note']) ? data.note is string && data.note.size() <= 500 : true) &&
                 data.timestamp is timestamp;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);

        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());

        allow update: if isOwner(userId) && isValidTransaction(incoming()) && (
          // Ensure ownership remains unchanged and limit partial updates if needed
          incoming().diff(existing()).affectedKeys().size() > 0
        );

        allow delete: if isOwner(userId);
      }
    }
  }
}
